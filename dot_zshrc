toilet --gay -t "Cymru am byth!"

zsh ~/.local/share/quotes/run.zsh

if [ ! -e ~/.local/share/znap/znap.zsh ]; then
	mkdir -p ~/.local/share/znap 
	git clone --depth 1 -- \
		https://github.com/marlonrichert/zsh-snap.git ~/.local/share/znap
fi

source ~/.local/share/znap/znap.zsh

export EDITOR='nvim'

alias zshconfig="nvim ~/.zshrc"

alias ls="exa -l --icons"
alias fd="fdfind"

alias flatup="flatpak update"

alias bsync="browser-sync start --server --files --no-open"

alias jupyter="~/.local/share/virtualenvs/datblygiad/bin/jupyter-lab"
alias python="~/.local/share/virtualenvs/datblygiad/bin/python"
alias code="vscodium"


# New functions
nvall () {
	if [ -z "$1" ]
	then
		echo "No filetype given"
	else
		fd -e "$@" -X nvim -p 
	fi
}

znap source 'zsh-users/zsh-syntax-highlighting'
znap source 'zsh-users/zsh-autosuggestions'
znap source 'zsh-users/zsh-history-substring-search'
znap source 'MichaelAquilina/zsh-auto-notify'

eval "$(starship init zsh)"
