figlet "Cymru am byth!"

[[ -r ~/.zsh/.znap/znap.zsh ]] ||
    git clone --depth 1 -- \
        https://github.com/marlonrichert/zsh-snap.git ~/.zsh/.znap
source ~/.zsh/.znap/znap.zsh

export EDITOR='nvim'

alias zshconfig="nvim ~/.zshrc"

alias ls="exa -l --icons"
alias fd="fdfind"

alias flatup="flatpak update"

alias bsync="browser-sync start --server --files --no-open"

alias jupyter="~/.pyenv/bin/jupyter-lab"
alias pip="~/.pyenv/bin/pip"
alias python="~/.pyenv/bin/python"


# New functions
nvall () {
	if [ -z "$1" ]
	then
		echo "No filetype given"
	else
		fd -e "$@" -X nvim -p 
	fi
}

eval "$(starship init zsh)"

znap source marlonrichert/zsh-autocomplete
